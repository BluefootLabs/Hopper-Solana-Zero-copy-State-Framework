# Catch-all: ignore planning docs
examples/*.md
docs/*.txt

# Memory / session files
memories/

# Benchmark fixtures (local keypairs, no real SOL but no reason to commit)
bench/fixtures/

# Local devnet proof wallets
examples/hopper-token-2022-vault/.local/

# Benchmark result artifacts (generated by hopper profile bench)
bench/results/

# ── AI assistants / coding agents (local only, never committed) ──
